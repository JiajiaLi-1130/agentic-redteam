{
  "name": "discover-skill",
  "version": "0.1.0",
  "description": "Draft a new harmless toy skill concept from repeated failure patterns.",
  "category": "meta",
  "stage": ["escalation"],
  "tags": ["toy", "meta", "discover"],
  "inputs": ["memory_summary", "extra.recent_memory", "evaluator_feedback"],
