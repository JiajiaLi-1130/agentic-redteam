{
  "name": "retrieval-analysis",
  "version": "0.1.0",
  "description": "Analyze recent toy failures and memory patterns.",
  "category": "analysis",
  "stage": ["analysis", "escalation"],
  "tags": ["toy", "retrieval", "analysis"],
  "inputs": ["memory_summary", "evaluator_feedback", "extra.recent_memory"],
